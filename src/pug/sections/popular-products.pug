.section-products__content 
	.section-products__column 
		.products-cart
			.products-cart__content 
				.products-cart__label
					+iconfont('fire', 'icon')
					.products-cart__label-text.t-text-15
						| хит сезона
				a(href=linkTo('product-card', filename)).products-cart__image 
					+picture('img/pic/pref-05.png', 'image')
				.products-cart__wrapper
					a(href=linkTo('product-card', filename)).products-cart__link.t-text-20 Авторский премиум - букет&nbsp;из&nbsp;роз 
					.products-cart__price.t-text-24
						span 8.870
						+iconfont('rub', 'icon')  
				.products-cart__button-container 
					a(href="").products-cart__button-cart.button 
						span.t-text-15 Подробнее
						.products-cart__icon-cart 
							+iconfont('arrow-right', 'icon') 
					a(href="").products-cart__button-by.button 
						span Купить в 1 клик
						.products-cart__icon-by
							+iconfont('arrow-right', 'icon')
