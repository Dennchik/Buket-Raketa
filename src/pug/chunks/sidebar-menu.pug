.menu-list
  .menu-list__body
    .menu-list__header 
      a(href="#home" aria-label="home").menu-list__logo
        +picture('/img/icons/logo.png', 'image') 
      .burger-button
        +iconfont('close-button', 'icon')
    .menu-list__content 
      .menu-list__list.bp-7
        .menu-list__list-item 
          a(href=linkTo('catalog', filename)).menu-list__link  
            span Каталог
        .menu-list__list-item 
          a(href=linkTo('delivery', filename)).menu-list__link  
            span Доставка
        .menu-list__list-item
          a(href=linkTo('about', filename)).menu-list__link 
            span О нас
        .menu-list__list-item
          a(href=linkTo('help', filename)).menu-list__link 
            span Помощ
        //- .menu-list__list-item
          a(href="" target="_blank").menu-list__link 
            .menu-list__icon 
              img(src="/img/icons/group.svg" alt="иконка")
            span Система лояльности  
      .menu-list__footer 
        .section-map__networks
          a(href="https://t.me/" target="_blank" data-letters="Телеграм")
            +iconfont('telegram-fly', 'icon') 
          a(href="https://vk.com/" target="_blank" data-letters="В контакте")
            +iconfont('vk-brand', 'icon')
          a(href="https://vk.com/" target="_blank" data-letters="Max")
            +iconfont('max-logo', 'icon') 
        .menu-list__phone 
          +iconfont('phone-call', 'icon')
          a(href="tel:8 (906) 849-97-43") 
            span +7 (906) 849-97-43 